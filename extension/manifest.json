{
  "manifest_version": 3,
  "name": "Cap Valoraciones",
  "version": "1.1",
  "description": "Obtiene valoraciones de Idealista y las escribe en Google Sheets",
  "key": "",
  "permissions": [
    "identity",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.idealista.com/es/vendorleads/*"],
      "js": [
        "content/dom-helpers.js",
        "content/form-automation.js",
        "content/price-extractor.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

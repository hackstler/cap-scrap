# Scrapfly: bypasses DataDome on Idealista (free 1000 credits, $33/mo for 150k)
SCRAPFLY_API_KEY=your-scrapfly-api-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro
GWS_CREDENTIALS_B64=base64-encoded-service-account-json
SHEET_ID=your-google-sheet-id
AUTH_TOKEN=shared-secret-with-apps-script
PORT=3000
# Optional: CapSolver for DataDome CAPTCHA solving (~$0.0025/solve)
CAPSOLVER_API_KEY=
# Optional: Residential proxy for anti-bot bypass (format: host:port:user:pass)
PROXY_URL=
# Batch strategy: how many properties per session before rotating IP
BATCH_SIZE=25
# Milliseconds between requests within a batch (default: 5000)
DELAY_BETWEEN_REQUESTS=5000
# Milliseconds between batches / IP rotations (default: 15000)
DELAY_BETWEEN_BATCHES=15000
